# ====================================
# Zentral — Environment Variables
# ====================================

# --- MongoDB ---
# Connection string for your MongoDB database
# Format: mongodb+srv://user:pass@host/dbname?appName=app
MONGO_URL=mongodb://localhost:27017/zentral

# --- JWT ---
# Secret key used to sign & verify JSON Web Tokens (session, password reset, email verification)
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-64-char-string

# --- Resend ---
# API key for transactional email delivery (verification, password reset)
# Get it at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- App ---
# Public URL of your deployed app (used in emails and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Upstash Redis (Rate Limiting) ---
# Tip: if any of these fail, rate limiting is silently bypassed.

# REST API URL from your Upstash Redis console
KV_REST_API_URL=https://your-region.upstash.io

# REST API Token from your Upstash Redis console
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ====================================
# Optional / Platform
# ====================================

# --- Node Environment ---
# NODE_ENV=production

# --- Upstash Redis connection strings (autoconfigured by Vercel/Railway) ---
# KV_URL=rediss://default:token@host:6379
# REDIS_URL=rediss://default:token@host:6379
