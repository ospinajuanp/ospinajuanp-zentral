# ====================================
# Zentral - Environment Variables
# ====================================

# --- MongoDB ---
# Connection string for your MongoDB database
MONGO_URL=mongodb://localhost:27017/zentral

# --- JWT ---
# Secret key used to sign & verify JSON Web Tokens (session, password reset, email verification)
JWT_SECRET=change-me-to-a-random-64-char-string

# --- Resend ---
# API key for transactional email delivery (verification, password reset)
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- App ---
# Public URL of your deployed app (used in emails and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Upstash Redis (Rate Limiting) ---
# Endpoint URL from your Upstash Redis console
KV_REST_API_URL=https://your-region.upstash.io
# Token from your Upstash Redis console
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ====================================
# Optional variables
# ====================================

# --- Node Environment ---
# NODE_ENV=production
